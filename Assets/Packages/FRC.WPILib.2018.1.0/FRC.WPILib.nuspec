  <metadata>
    <id>FRC.WPILib</id>
    <version>2018.1.0</version>
    <title>FRC WPILib</title>
    <authors>RobotDotNet</authors>
    <owners>RobotDotNet</owners>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
