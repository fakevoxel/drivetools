<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>FRC.WPILibNativeLibraries</id>
    <version>2018.1.0</version>
    <title>FRC WPILibNativeLibraries</title>
    <authors>RobotDotNet</authors>
    <owners>RobotDotNet</owners>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <projectUrl>https://github.com/robotdotnet/WPILib/WPILibNativeLibraries</projectUrl>
    <description>Contains the roboRIO libraries to run WPILib in C#</description>
    <copyright>2016-2017</copyright>
    <tags>WPILib FIRST FRC RoboRIO</tags>
    <contentFiles>
      <files include="**/wpinative/*.*" buildAction="None" copyToOutput="true" />
    </contentFiles>
  </metadata>
</package>